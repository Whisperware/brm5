local TargetSizing = {}

-- Store full original state, not just size
TargetSizing.originalStates = {}

-- Internal: safely resolve root part
function TargetSizing:_getRoot(model, npcManager)
    local data = npcManager:getActiveNPCs()[model]
    
    if data and data.root then
        return data.root
    end

    if data and data.character then
        return npcManager:getRootPart(data.character)
    end

    return npcManager:getRootPart(model)
end

-- Apply sizing to a single NPC
function TargetSizing:applyTargetSizing(model, root, config)
    if not root or not config or not config.TARGET_BOX_SIZE then
        return
    end

    -- Save original state once
    if not self.originalStates[model] then
        self.originalStates[model] = {
            size = root.Size,
            transparency = root.Transparency,
            canCollide = root.CanCollide
        }
    end

    -- Apply size
    if root.Size ~= config.TARGET_BOX_SIZE then
        root.Size = config.TARGET_BOX_SIZE
    end

    -- Apply transparency
    local targetTransparency = config.showTargetBox and 0.85 or 1
    if root.Transparency ~= targetTransparency then
        root.Transparency = targetTransparency
    end

    -- Ensure collision enabled
    if root.CanCollide ~= true then
        root.CanCollide = true
    end
end

-- Restore original state
function TargetSizing:restoreOriginal(model, npcManager)
    local original = self.originalStates[model]
    if not original then return end

    local root = self:_getRoot(model, npcManager)
    if root then
        root.Size = original.size
        root.Transparency = original.transparency
        root.CanCollide = original.canCollide
    end

    self.originalStates[model] = nil
end

-- Update all NPCs
function TargetSizing:updateAllTargets(npcManager, config)
    if not config or not config.sizingEnabled then
        if next(self.originalStates) then
            self:cleanup(npcManager)
        end
        return
    end

    local activeNPCs = npcManager:getActiveNPCs()

    -- Apply to active NPCs
    for model, data in pairs(activeNPCs) do
        if data.root then
            self:applyTargetSizing(model, data.root, config)
        end
    end

    -- Cleanup models that no longer exist
    for model, _ in pairs(self.originalStates) do
        if not activeNPCs[model] or not model.Parent then
            self.originalStates[model] = nil
        end
    end
end

-- Cleanup everything
function TargetSizing:cleanup(npcManager)
    for model, _ in pairs(self.originalStates) do
        self:restoreOriginal(model, npcManager)
    end
end

return TargetSizing
